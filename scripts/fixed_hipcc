#!/bin/bash

# 1. Find the real hipcc executable
REAL_HIPCC=$(type -P hipcc)

if [ -z "$REAL_HIPCC" ]; then
    echo "Error: hipcc not found in PATH."
    exit 1
fi

# 2. Filter arguments
CLEAN_ARGS=()

for arg in "$@"; do
    case "$arg" in
        -fcf-protection*)
            # Skip Fedora hardening flags
            ;;
        *)
            CLEAN_ARGS+=("$arg")
            ;;
    esac
done

# 3. Force -Wno-narrowing to fix o-voxel compliance issues
CLEAN_ARGS+=("-Wno-narrowing")

# 4. Execute
exec "$REAL_HIPCC" "${CLEAN_ARGS[@]}"